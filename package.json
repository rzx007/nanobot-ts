{
  "name": "nanobot-ts",
  "version": "0.1.1",
  "description": "Ultra-lightweight personal AI assistant - TypeScript implementation",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "nanobot-ts": "./packages/cli/dist/index.js"
  },
  "scripts": {
    "build": "cd packages/cli && bun run build && cd ../web && bun run build",
    "build:binary": "bun build ./packages/cli/src/index.ts --compile --outfile nanobot",
    "dev": "NODE_ENV=development bun --watch packages/cli/src/run.ts",
    "start": "bun packages/cli/dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"packages/**/*.ts\"",
    "typecheck": "bun tsc --noEmit",
    "clean": "rm -rf packages/*/dist node_modules/.cache",
    "tui": "bun packages/cli/dist/run.js tui",
    "onboard": "bun packages/cli/dist/run.js init",
    "gateway": "bun packages/cli/dist/run.js gateway",
    "status": "bun packages/cli/dist/run.js status"
  },
  "keywords": [
    "ai",
    "agent",
    "chatbot",
    "llm",
    "typescript",
    "assistant"
  ],
  "author": "Nanobot TypeScript Team",
  "license": "MIT",
  "packageManager": "bun@1.3.10",
  "engines": {
    "bun": ">=1.3.10"
  },
  "peerDependencies": {
    "bun": ">=1.3.10"
  },
  "resolutions": {
    "fast-xml-parser": "4.5.1"
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rzx007/nanobot-ts.git"
  }
}
