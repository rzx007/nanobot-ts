{
  "name": "@nanobot/main",
  "version": "0.1.1",
  "description": "Core framework for nanobot-ts (Agent, Memory, Approval, Tools, Skills, MCP)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm && tsc --emitDeclarationOnly --outDir ./dist",
    "typecheck": "bun tsc --noEmit"
  },
  "keywords": [
    "nanobot",
    "core",
    "agent",
    "tools",
    "skills",
    "mcp"
  ],
  "author": "Nanobot TypeScript Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@nanobot/channels": "workspace:*",
    "@nanobot/logger": "workspace:*",
    "@nanobot/providers": "workspace:*",
    "@nanobot/shared": "workspace:*",
    "@nanobot/utils": "workspace:*",
    "agent-browser": "^0.16.3",
    "ai": "catalog:",
    "bunqueue": "^2.6.5",
    "cheerio": "^1.2.0",
    "cosmiconfig": "^9.0.0",
    "croner": "^10.0.1",
    "defuddle": "^0.13.0",
    "drizzle-orm": "^0.45.1",
    "eventemitter3": "^5.0.4",
    "execa": "^9.6.1",
    "fs-extra": "^11.2.0",
    "gray-matter": "^4.0.3",
    "inquirer": "^13.3.0",
    "jsdom": "^24.0.0",
    "markdown-it": "^14.1.1",
    "opentui-spinner": "^0.0.6"
  },
  "devDependencies": {
    "@types/execa": "^2.0.2",
    "@types/fs-extra": "^11.0.4",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  }
}
