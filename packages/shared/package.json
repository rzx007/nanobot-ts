{
  "name": "@nanobot/shared",
  "version": "0.1.1",
  "description": "Shared types and configuration for nanobot-ts",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm && tsc --emitDeclarationOnly --outDir ./dist",
    "typecheck": "bun tsc --noEmit"
  },
  "keywords": [
    "nanobot",
    "types",
    "config"
  ],
  "author": "Nanobot TypeScript Team",
  "license": "MIT",
  "dependencies": {
    "@nanobot/providers": "workspace:*",
    "@types/fs-extra": "^11.0.4",
    "cosmiconfig": "^9.0.1",
    "fs-extra": "^11.3.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "ai": "^6.0.116",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  }
}
