{
  "name": "@nanobot/skills",
  "version": "0.1.1",
  "description": "Skills loader for nanobot-ts",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm && tsc --emitDeclarationOnly --outDir ./dist",
    "typecheck": "bun tsc --noEmit"
  },
  "keywords": [
    "nanobot",
    "skills"
  ],
  "author": "Nanobot TypeScript Team",
  "license": "MIT",
  "dependencies": {
    "@nanobot/logger": "workspace:*",
    "@nanobot/utils": "workspace:*",
    "@nanobot/shared": "workspace:*",
    "cosmiconfig": "^9.0.0",
    "jsdom": "^24.0.0"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.9.3"
  }
}
