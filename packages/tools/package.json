{
  "name": "@nanobot/tools",
  "version": "0.1.1",
  "description": "AI tools collection for nanobot-ts",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm && tsc --emitDeclarationOnly --outDir ./dist",
    "typecheck": "bun tsc --noEmit"
  },
  "keywords": [
    "nanobot",
    "tools"
  ],
  "author": "Nanobot TypeScript Team",
  "license": "MIT",
  "dependencies": {
    "@nanobot/shared": "workspace:*",
    "@nanobot/logger": "workspace:*",
    "@nanobot/utils": "workspace:*",
    "ai": "^6.0.99",
    "agent-browser": "^0.16.3",
    "bunqueue": "^2.6.5",
    "cheerio": "^1.2.0",
    "execa": "^9.6.1",
    "croner": "^10.0.1",
    "gray-matter": "^4.0.3",
    "markdown-it": "^14.1.1",
    "opentui-spinner": "^0.0.6"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.9.3"
  }
}
