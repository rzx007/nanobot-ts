{
  "name": "@nanobot/tui",
  "version": "0.1.1",
  "description": "Terminal UI for nanobot-ts",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm && tsc --emitDeclarationOnly",
    "typecheck": "bun tsc --noEmit"
  },
  "keywords": [
    "nanobot",
    "tui"
  ],
  "author": "Nanobot TypeScript Team",
  "license": "MIT",
  "dependencies": {
    "@nanobot/channels": "workspace:*",
    "@nanobot/cli": "workspace:*",
    "@nanobot/logger": "workspace:*",
    "@nanobot/main": "workspace:*",
    "@nanobot/shared": "workspace:*",
    "@nanobot/utils": "workspace:*",
    "@opentui/core": "latest",
    "@opentui/react": "latest",
    "cosmiconfig": "^9.0.1",
    "fs-extra": "^11.2.0",
    "opentui-spinner": "^0.0.6",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/fs-extra": "^11.0.4",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  }
}
