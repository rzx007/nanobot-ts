{
  "name": "@nanobot/tui",
  "version": "0.1.1",
  "description": "Terminal UI for nanobot-ts",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm",
    "typecheck": "bun tsc --noEmit"
  },
  "keywords": [
    "nanobot",
    "tui"
  ],
  "author": "Nanobot TypeScript Team",
  "license": "MIT",
  "dependencies": {
    "@nanobot/main": "workspace:*",
    "@nanobot/logger": "workspace:*",
    "@nanobot/utils": "workspace:*",
    "@opentui/core": "latest",
    "@opentui/react": "latest",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "bun-types": "latest",
    "typescript": "^5.9.3"
  }
}
