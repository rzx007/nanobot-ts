{
  "name": "@nanobot/utils",
  "version": "0.1.1",
  "description": "Utility functions for nanobot-ts",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm && tsc --emitDeclarationOnly --outDir ./dist",
    "typecheck": "bun tsc --noEmit"
  },
  "keywords": [
    "nanobot",
    "utils"
  ],
  "author": "Nanobot TypeScript Team",
  "license": "MIT",
  "dependencies": {
    "@types/fs-extra": "^11.0.4",
    "fs-extra": "^11.3.4"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.9.3"
  }
}
