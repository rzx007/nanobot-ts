{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/react",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "removeComments": false,
    "newLine": "lf",
    "isolatedModules": true,
    "allowImportingTsExtensions": false,
    "paths": {
      "@/*": ["./src/*"],
      "@nanobot/shared": ["./packages/shared/src"],
      "@nanobot/logger": ["./packages/logger/src"],
      "@nanobot/utils": ["./packages/utils/src"],
      "@nanobot/main": ["./packages/main/src"],
      "@nanobot/providers": ["./packages/providers/src"],
      "@nanobot/tools": ["./packages/tools/src"],
      "@nanobot/channels": ["./packages/channels/src"],
      "@nanobot/cli": ["./packages/cli/src"],
      "@nanobot/tui": ["./packages/tui/src"],
      "@nanobot/server": ["./packages/server/src"],
      "@nanobot/skills": ["./packages/skills/src"],
      "@nanobot/mcp": ["./packages/mcp/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "**/*.test.ts", "**/*.spec.ts", "templates", "tests"],
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    }
  }
}
